# ─── Copy this to .env and fill in your values ───────────────────────────────

# Supabase — get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key...

# Backend API URL — your Railway backend service URL (no trailing slash)
# In dev this is proxied by Vite, so leave blank or use http://localhost:3001
VITE_API_URL=https://your-backend.up.railway.app

# CD invite code — share this privately with Contest Directors only
VITE_CD_INVITE_CODE=GC-CD-2025
